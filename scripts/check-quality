#!/usr/bin/env bash
# Repeatable quality checks for selected homework directories.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BUILD_DIR="${BUILD_DIR:-$ROOT/build/debug}"
PRESET="${PRESET:-debug}"
QUALITY_DIRS_RAW="${QUALITY_DIRS:-homework_06 homework_07}"
CMAKE_FORMAT_CONFIG="${CMAKE_FORMAT_CONFIG:-/.cmake-format.json}"

# clang-tidy does not read /.clang-tidy automatically; pass --config-file explicitly.
# Prefer $ROOT/.devcontainer/.clang-tidy over image-baked /.clang-tidy so git pull
# updates lint rules without rebuilding the devcontainer image.
resolve_clang_tidy_config() {
    local candidate=""

    if [[ -n "${CLANG_TIDY_CONFIG_OVERRIDE:-}" ]]; then
        candidate="$CLANG_TIDY_CONFIG_OVERRIDE"
        if [[ -f "$candidate" ]]; then
            echo "$candidate"
            return
        fi
        if [[ -f "$ROOT/$candidate" ]]; then
            echo "$ROOT/$candidate"
            return
        fi
        echo "Warning: CLANG_TIDY_CONFIG_OVERRIDE=$CLANG_TIDY_CONFIG_OVERRIDE not found" >&2
    fi

    if [[ -f "$ROOT/.devcontainer/.clang-tidy" ]]; then
        echo "$ROOT/.devcontainer/.clang-tidy"
        return
    fi
    if [[ -f /.clang-tidy ]]; then
        echo /.clang-tidy
        return
    fi
    echo "Warning: no .clang-tidy found; clang-tidy uses LLVM defaults" >&2
}

CLANG_TIDY_CONFIG="$(resolve_clang_tidy_config)"

read -r -a QUALITY_DIRS <<< "$QUALITY_DIRS_RAW"
if [[ "${#QUALITY_DIRS[@]}" -eq 0 ]]; then
    echo "Error: QUALITY_DIRS is empty" >&2
    exit 1
fi

declare -a QUALITY_TARGET_DIRS=()
for relative_dir in "${QUALITY_DIRS[@]}"; do
    absolute_dir="$ROOT/$relative_dir"
    if [[ ! -d "$absolute_dir" ]]; then
        echo "Error: quality directory not found: $relative_dir" >&2
        exit 1
    fi
    QUALITY_TARGET_DIRS+=("$absolute_dir")
done

QUALITY_DIR_PATTERN=""
for relative_dir in "${QUALITY_DIRS[@]}"; do
    if [[ -n "$QUALITY_DIR_PATTERN" ]]; then
        QUALITY_DIR_PATTERN+="|"
    fi
    QUALITY_DIR_PATTERN+="$relative_dir"
done

# clang-tidy header-filter: project dirs only, never vendored json.hpp (25k+ lines).
build_lint_header_filter() {
    echo "^(?!.*/json\\.hpp$).*/(${QUALITY_DIR_PATTERN})/"
}

is_vendored_file() {
    local file="$1"
    case "$file" in
        */include/json.hpp | */json.hpp) return 0 ;;
        */_deps/* | */googletest/*) return 0 ;;
        *) return 1 ;;
    esac
}

collect_format_files() {
    local dir="$1"
    find "$dir" -type f \( -name '*.cpp' -o -name '*.cc' -o -name '*.cxx' -o -name '*.hpp' -o -name '*.h' \) -print0
}

collect_lint_files() {
    local dir="$1"
    find "$dir" -type f \( -name '*.cpp' -o -name '*.cc' -o -name '*.cxx' \) -print0
}

cd "$ROOT"

format() {
    echo "==> format"
    local dir
    for dir in "${QUALITY_TARGET_DIRS[@]}"; do
        echo "format: $dir"
        while IFS= read -r -d '' file; do
            if is_vendored_file "$file"; then
                echo "skip vendored format: $file"
                continue
            fi
            clang-format -i "$file"
        done < <(collect_format_files "$dir")

        find "$dir" \( -name 'CMakeLists.txt' -o -name '*.cmake' \) -print0 \
            | xargs -0 -r cmake-format -i --config-file="$CMAKE_FORMAT_CONFIG"
    done
}

build() {
    echo "==> build"
    cmake --preset "$PRESET"
    cmake --build --preset "$PRESET"
}

test() {
    echo "==> test"
    build
    ctest --test-dir "$BUILD_DIR" --output-on-failure
}

lint_sources() {
    echo "==> lint_sources"
    local failed=0
    local file

    echo "ROOT=$ROOT"
    echo "BUILD_DIR=$BUILD_DIR"
    if [[ -n "$CLANG_TIDY_CONFIG" ]]; then
        echo "clang-tidy config: $CLANG_TIDY_CONFIG"
    else
        echo "clang-tidy config: (LLVM defaults)" >&2
    fi

    local header_filter
    header_filter="$(build_lint_header_filter)"
    echo "clang-tidy header-filter: $header_filter (excludes vendored json.hpp)"

    while IFS= read -r -d '' file; do
        if is_vendored_file "$file"; then
            echo "skip vendored lint: $file"
            continue
        fi
        echo "clang-tidy: $file"
        tidy_args=("$file" -p "$BUILD_DIR" --header-filter="$header_filter")
        if [[ -n "$CLANG_TIDY_CONFIG" ]]; then
            tidy_args+=(--config-file="$CLANG_TIDY_CONFIG")
        fi
        if ! clang-tidy "${tidy_args[@]}"; then
            echo "clang-tidy failed for: $file" >&2
            failed=1
        fi
    done < <(
        for dir in "${QUALITY_TARGET_DIRS[@]}"; do
            collect_lint_files "$dir"
        done
    )

    return "$failed"
}

lint() {
    echo "==> lint"
    build
    lint_sources
}

usage() {
    cat <<EOF
Usage: $(basename "$0") <command>

Commands:
  format   clang-format + cmake-format for QUALITY_DIRS
  build    cmake preset debug (override with PRESET=...)
  test     build + ctest in BUILD_DIR (default: build/debug)
  lint     build + clang-tidy on QUALITY_DIRS sources
  quality  format + build + test + lint (run before PR)
  config   print resolved ROOT, BUILD_DIR, clang-tidy config (debug)

Environment:
  BUILD_DIR                   default: \$ROOT/build/debug
  PRESET                      default: debug
  QUALITY_DIRS                default: "homework_06 homework_07"
  CMAKE_FORMAT_CONFIG         default: /.cmake-format.json (devcontainer)
  CLANG_TIDY_CONFIG_OVERRIDE  optional path to .clang-tidy (absolute or relative to ROOT)
EOF
}

print_config() {
    echo "ROOT=$ROOT"
    echo "BUILD_DIR=$BUILD_DIR"
    echo "QUALITY_DIRS=${QUALITY_DIRS[*]}"
    echo "QUALITY_TARGET_DIRS=${QUALITY_TARGET_DIRS[*]}"
    if [[ -n "$CLANG_TIDY_CONFIG" ]]; then
        echo "clang-tidy config: $CLANG_TIDY_CONFIG"
        if command -v clang-tidy >/dev/null 2>&1; then
            if clang-tidy --list-checks --config-file="$CLANG_TIDY_CONFIG" 2>/dev/null \
                | grep -q 'readability-identifier-naming'; then
                echo "WARNING: readability-identifier-naming is ENABLED in this config" >&2
            else
                echo "readability-identifier-naming: disabled (expected)"
            fi
        fi
    else
        echo "clang-tidy config: (LLVM defaults)" >&2
    fi
}

cmd="${1:-quality}"
case "$cmd" in
    format) format ;;
    build) build ;;
    test) test ;;
    lint) lint ;;
    config) print_config ;;
    quality)
        format
        build
        ctest --test-dir "$BUILD_DIR" --output-on-failure
        lint_sources
        ;;
    -h | --help | help) usage ;;
    *)
        echo "Unknown command: $cmd" >&2
        usage >&2
        exit 1
        ;;
esac
